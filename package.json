    "test:e2e": "node test/e2e.mjs"
  },
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@rive-app/canvas": "^2.38.5",
    "@rive-app/canvas-advanced": "^2.30.3",
    "gifenc": "^1.0.3",
    "playwright-core": "^1.53.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.0"
  }
}
