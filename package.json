{
  "name": "rive-mcp-server",
  "version": "0.1.0",
  "mcpName": "io.github.odu33104/rive-mcp",
  "description": "Free, editor-less MCP server for Rive: create, edit, inspect, render and live-preview .riv animations from Claude or any MCP client",
  "keywords": ["rive", "riv", "mcp", "model-context-protocol", "animation", "claude", "state-machine", "rigging"],
  "repository": { "type": "git", "url": "git+https://github.com/ODU33104/rive-mcp.git" },
  "homepage": "https://github.com/ODU33104/rive-mcp#readme",
  "bugs": { "url": "https://github.com/ODU33104/rive-mcp/issues" },
  "engines": { "node": ">=20" },
  "type": "module",
  "bin": {
    "rive-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "assets",
    "vendor/rive-defs/defs.json"
  ],
  "scripts": {
    "vendor": "node scripts/vendor.mjs",
